# Kopieer naar .env.local (lokaal) of zet deze waarden in ~/appportal/.env (op de VM).
# Nooit committen — .env* staat in .gitignore.

# Pipedrive API-tokens per account (Pipedrive > Instellingen > Persoonlijk > API).
PIPEDRIVE_TOKEN_HARCHITECTS=
PIPEDRIVE_TOKEN_UNABO=
PIPEDRIVE_TOKEN_TKNBURO=
PIPEDRIVE_TOKEN_ENERGIEEFFICIENT=

# Anthropic API-key voor het analyse-panel (console.anthropic.com).
ANTHROPIC_API_KEY=
